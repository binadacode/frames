rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }
    
    function isValidWaitlistEntry(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.keys().size() == 2
        && data.email is string
        && data.email.size() >= 3
        && data.email.size() <= 254
        && data.email.matches('.*@.*\\..*')
        && data.createdAt == request.time;
    }

    match /waitlist/{entryId} {
      // Anyone can add themselves to the waitlist
      allow create: if isValidWaitlistEntry(incoming());
      // No reads, updates, or deletes allowed to the public
      allow read, update, delete: if false;
    }
  }
}
